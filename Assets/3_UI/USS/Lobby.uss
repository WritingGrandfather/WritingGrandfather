.hidden {
    display: none;
}

.lobby-root {
    position: absolute;
    width: 100%;
    height: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    background-color: rgb(250, 240, 222);
}

.title-area {
    width: 100%;
    min-height: 260px;
    flex-grow: 1;
    flex-shrink: 0;
    overflow: hidden;
    justify-content: center;
    align-items: center;
    padding: 0 40px;
}

.title-label {
    font-size: 60px;
    -unity-font-style: bold;
    color: rgb(90, 62, 40);
    -unity-text-align: middle-center;
    white-space: normal;
}

.button-area {
    flex-grow: 2;
    width: 80%;
    justify-content: center;
    align-items: stretch;
    margin-bottom: 120px;
}

.menu-button {
    height: 130px;
    margin-bottom: 32px;
    border-radius: 28px;
    border-width: 0;
    font-size: 44px;
    color: rgb(255, 255, 255);
    background-color: rgb(150, 111, 71);
    -unity-text-align: middle-center;
}

.menu-button:hover {
    background-color: rgb(170, 128, 86);
}

.menu-button--primary {
    background-color: rgb(214, 108, 58);
}

.menu-button--primary:hover {
    background-color: rgb(230, 128, 76);
}

.menu-button--exit {
    background-color: rgb(120, 120, 120);
}

.menu-button--exit:hover {
    background-color: rgb(140, 140, 140);
}

.modal-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.6);
}

.modal-box {
    width: 75%;
    background-color: rgb(255, 253, 248);
    border-radius: 32px;
    padding: 48px 32px;
    align-items: center;
}

.modal-text {
    font-size: 40px;
    color: rgb(60, 45, 35);
    margin-bottom: 48px;
    -unity-text-align: middle-center;
    white-space: normal;
}

.modal-button-row {
    flex-direction: row;
    width: 100%;
    justify-content: space-between;
}

.modal-button {
    flex-grow: 1;
    height: 96px;
    margin: 0 8px;
    border-radius: 20px;
    border-width: 0;
    font-size: 34px;
    color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
}

.modal-button--confirm {
    background-color: rgb(214, 108, 58);
}

.modal-button--confirm:hover {
    background-color: rgb(230, 128, 76);
}

.modal-button--cancel {
    background-color: rgb(120, 120, 120);
}

.modal-button--cancel:hover {
    background-color: rgb(140, 140, 140);
}
